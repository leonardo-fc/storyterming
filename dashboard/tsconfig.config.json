{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist/temp", // Prevent error with .js file.
    "allowJs": true,
    "checkJs": true
  },
  "include": ["./*.ts", "./*.js", "./*.cjs", "scripts/*.ts"]
}
