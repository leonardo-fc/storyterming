{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": "src",
    "paths": { "~/*": ["*"] }
  },
  "include": [
    "src/*.ts",
    "src/server/**/*.ts",
    "src/functions/**/*.ts",
    "src/types.ts"
  ]
}
